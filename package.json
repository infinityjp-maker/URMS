{
  "name": "urms",
  "version": "0.2.0",
  "private": true,
  "description": "Unified Resource Management System",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @urms/web dev",
    "dev:api": "pnpm --filter @urms/api dev",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @urms/db db:migrate",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "wireframes": "pnpm wireframes:serve",
    "wireframes:serve": "pnpm exec serve docs/design/wireframes -l 5180",
    "preview:web": "pnpm --filter @urms/web build && pnpm --filter @urms/web preview",
    "build": "pnpm --filter @urms/shared build && pnpm --filter @urms/domain build && pnpm --filter @urms/logger build && pnpm --filter @urms/plugin-ollama build && pnpm --filter @urms/plugin-resource-types build && pnpm --filter @urms/db build && pnpm --filter @urms/api build && pnpm --filter @urms/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @urms/domain test && pnpm --filter @urms/plugin-ollama test && pnpm --filter @urms/plugin-resource-types test && pnpm --filter @urms/db test && pnpm --filter @urms/api test && pnpm --filter @urms/web test",
    "test:coverage": "pnpm --filter @urms/domain test:coverage && pnpm --filter @urms/api test:coverage",
    "test:integration": "pnpm --filter @urms/db test:integration && pnpm --filter @urms/api test:integration",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.51.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "serve": "^14.2.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
