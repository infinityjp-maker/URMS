# URMS — 環境変数テンプレート
# 秘密情報は .env にのみ配置し、コミットしない
#
# 使い方:
#   copy .env.example .env
#
# ローカル開発（DB のみ Docker）: pnpm db:up && pnpm db:migrate
# 一式起動（MVP）: pnpm docker:up → http://localhost:8080/

# Database（packages/db, apps/api）
# ローカル dev: localhost / Docker Compose api コンテナ: postgres
DATABASE_URL=postgresql://urms:urms@localhost:5432/urms?schema=public

# API（apps/api）
PORT=3000
HOST=0.0.0.0
# bypass = 開発確認用（デフォルト · ログイン UI なし）| local = 内部 JWT 検証（UI なし）
URMS_AUTH_MODE=bypass
URMS_AUTH_BYPASS=true
LOG_LEVEL=info

# ローカル認証（URMS_AUTH_MODE=local のとき必須）
# JWT_SECRET=change-me-in-production
# 初回ユーザー: pnpm --filter @urms/db db:seed-local （operator / change-me）

# Web（apps/web）
# 開発時は Vite proxy 利用のため空文字で可
# Docker Compose（nginx 経由）でも空文字 — 同一オリジンで /v1 をプロキシ
VITE_API_BASE_URL=

# AI（S7 — ff.ai.enabled を true にすると /v1/ai/* が有効）
URMS_FF_AI_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434

# 知覚層 — 天気 v2a（Open-Meteo · API キー不要 · 既定: 東京）
# URMS_WEATHER_ENABLED=true
# URMS_WEATHER_LAT=35.6762
# URMS_WEATHER_LON=139.6503
# URMS_WEATHER_TIMEZONE=Asia/Tokyo

# 知覚層 — 予定 v2b（resourceType=schedule · metadata.startAt ISO）
# POST /v1/resources で schedule を active 登録すると窓に表示
# URMS_SCHEDULE_ENABLED=true
# URMS_SCHEDULE_TIMEZONE=Asia/Tokyo
# URMS_SCHEDULE_LIMIT=8

# Docker Compose 公開ポート（nginx サービス）
URMS_HTTP_PORT=8080

# 本番向け（Phase 4 S11 ローカル認証 · クラウド IdP は不使用 ADR-022）
# URMS_AUTH_MODE=local
# JWT_SECRET=
# NODE_ENV=production
