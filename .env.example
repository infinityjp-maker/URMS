# URMS — 環境変数テンプレート
# 秘密情報は .env にのみ配置し、コミットしない

# Database（packages/db, apps/api）
DATABASE_URL=postgresql://urms:urms@localhost:5432/urms?schema=public

# API（apps/api）
PORT=3000
URMS_AUTH_BYPASS=true
LOG_LEVEL=info

# Web（apps/web）— 開発時は Vite proxy 利用のため空文字で可
VITE_API_BASE_URL=

# AI（S7 — ff.ai.enabled を true にすると /v1/ai/* が有効）
URMS_FF_AI_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
