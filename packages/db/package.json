{
  "name": "@urms/db",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate && tsc -p tsconfig.json",
    "lint": "eslint src",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "db:migrate": "tsx scripts/prisma-cli.ts migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed-local": "tsx scripts/seed-local-user.ts",
    "ai-team:sync": "tsx scripts/sync-ai-team.ts",
    "schedule:sync": "tsx scripts/sync-schedule.ts",
    "location:sync": "tsx scripts/sync-location.ts",
    "loop:sync": "tsx scripts/sync-loop.ts",
    "loop:export": "tsx scripts/export-loop.ts",
    "ssot:sync": "tsx scripts/sync-ssot.ts",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "@urms/domain": "workspace:*",
    "@urms/shared": "workspace:*"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.17.2",
    "@types/node": "^22.10.7",
    "prisma": "^6.3.1",
    "tsx": "^4.19.2",
    "testcontainers": "^10.17.2",
    "vitest": "^3.0.5"
  }
}
