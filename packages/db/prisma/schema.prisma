generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ResourceStatus {
  draft
  active
  deprecated
  archived
}

model Resource {
  id           String         @id @default(cuid())
  resourceType String         @map("resource_type")
  resourceId   String         @map("resource_id")
  name         String
  status       ResourceStatus @default(draft)
  metadata     Json           @default("{}")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  createdBy    String?        @map("created_by")
  updatedBy    String?        @map("updated_by")

  @@unique([resourceType, resourceId])
  @@index([resourceType, status])
  @@index([name])
  @@map("resources")
}

model ContextSnapshot {
  id                String   @id @default(cuid())
  key               String   @unique
  summary           String
  ssotLinks         Json     @map("ssot_links")
  exportContentHash String?  @map("export_content_hash")
  updatedAt         DateTime @updatedAt @map("updated_at")
  updatedBy         String?  @map("updated_by")

  @@map("context_snapshots")
}

model AuditLog {
  id           String   @id @default(cuid())
  action       String
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  actorId      String   @map("actor_id")
  mode         String
  payload      Json?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

model User {
  id           String   @id @default(cuid())
  externalId   String   @unique @map("external_id")
  email        String   @unique
  displayName  String?  @map("display_name")
  passwordHash String?  @map("password_hash")
  roles        String[] @default([])
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("users")
}

model AiUsageLog {
  id               String   @id @default(cuid())
  providerId       String   @map("provider_id")
  modelId          String   @map("model_id")
  promptTokens     Int      @default(0) @map("prompt_tokens")
  completionTokens Int      @default(0) @map("completion_tokens")
  latencyMs        Int      @map("latency_ms")
  costUsd          Decimal? @map("cost_usd") @db.Decimal(10, 6)
  actorId          String   @map("actor_id")
  mode             String
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("ai_usage_logs")
}

model ResourceRelation {
  id           String   @id @default(cuid())
  fromType     String   @map("from_type")
  fromId       String   @map("from_id")
  toType       String   @map("to_type")
  toId         String   @map("to_id")
  relationType String   @map("relation_type")
  createdAt    DateTime @default(now()) @map("created_at")
  createdBy    String?  @map("created_by")

  @@unique([fromType, fromId, toType, toId, relationType])
  @@index([fromType, fromId])
  @@index([toType, toId])
  @@map("resource_relations")
}
